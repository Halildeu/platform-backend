{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Authz Check p95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=~\"/v1/authz/check|/api/v1/authz/check|/v1/authz/batch-check|/api/v1/authz/batch-check\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 (ms)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{uri=~\"/v1/authz/check|/api/v1/authz/check\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50 (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 150 }
            ]
          },
          "unit": "ms"
        }
      }
    },
    {
      "title": "Authz Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/v1/authz/.*|/api/v1/authz/.*\"}[5m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/v1/authz/.*|/api/v1/authz/.*\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Deny Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/v1/authz/check|/api/v1/authz/check\",status=~\"403|401\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{uri=~\"/v1/authz/check|/api/v1/authz/check\"}[5m])), 0.001) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "OpenFGA Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "up{job=\"openfga\"}",
          "legendFormat": "OpenFGA",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "AuthzVersion",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "targets": [
        {
          "expr": "http_server_requests_seconds_count{uri=\"/api/v1/authz/version\"}",
          "legendFormat": "version poll count",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Authz Endpoint Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (uri) (http_server_requests_seconds_count{uri=~\"/v1/authz/.*|/api/v1/authz/.*\"})",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["zanzibar", "authz", "openfga"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Zanzibar Authorization",
  "uid": "zanzibar-authz",
  "version": 1
}
