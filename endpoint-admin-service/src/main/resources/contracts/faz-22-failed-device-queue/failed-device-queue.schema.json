{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platform.local/contracts/faz-22-failed-device-queue.schema.json",
  "title": "Failed-Device Queue Contract (Faz 22.5, #520)",
  "description": "Machine-enforced contract for the 50->800 rollout failed-device queue. v1 runtime supports live queue ingest, advisory threshold evaluation, read-only escalation generation, and a fail-closed canonical waveFailureReport export. Deployment enforcement remains explicitly false unless a separate rollout-gating control lands. Cross-AI design+review: Codex 019eaac8. The root validates a documentation BUNDLE (one of each artifact); runtime artifacts validate against the named $defs (queueItem / event / waveFailureReport via $anchor).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "queueItem", "event", "waveFailureReport"],
  "properties": {
    "schemaVersion": { "const": "failed-device-queue/v1" },
    "failureClass": { "$ref": "#/$defs/failureClass" },
    "queueState": { "$ref": "#/$defs/queueState" },
    "queueItem": { "$ref": "#/$defs/queueItem" },
    "event": { "$ref": "#/$defs/event" },
    "waveFailureReport": { "$ref": "#/$defs/waveFailureReport" }
  },
  "$defs": {
    "failureClass": {
      "type": "string",
      "enum": ["DNS_EDGE_MTLS", "CERT_IDENTITY", "INSTALLER_MSI", "SERVICE_HMAC_MODE", "BACKEND_RESULT_SUBMIT", "EDR_NETWORK"]
    },
    "queueState": {
      "type": "string",
      "enum": ["new", "retrying", "quarantined", "escalated", "resolved", "waived"]
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "stopLineStatus": { "type": "string", "enum": ["clear", "stop_expansion", "required_review"] },
    "uuid": { "type": "string", "format": "uuid" },
    "hashHex": { "type": "string", "pattern": "^[0-9a-f]{8,64}$" },
    "nullableHashHex": { "type": ["string", "null"], "pattern": "^[0-9a-f]{8,64}$" },
    "redactedString": {
      "description": "Free string that MUST be a redaction marker, not a raw value — guards log/PII leak (Codex must-fix 4).",
      "type": ["string", "null"],
      "pattern": "^(\\[redacted|redacted:)"
    },
    "evidence": {
      "description": "Per-class allowlisted redacted evidence. additionalProperties:false forbids raw last_error/tokens/PEM; every contract-listed field is REQUIRED (nullable where N/A) so an audit artifact cannot silently omit evidence (Codex must-fix 3).",
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "endpoint_host_hash", "edge_target", "dns_error_code", "tls_alert", "mtls_peer_cert_fingerprint_prefix", "observed_at", "source"],
          "properties": {
            "class": { "const": "DNS_EDGE_MTLS" },
            "endpoint_host_hash": { "$ref": "#/$defs/hashHex" },
            "edge_target": { "type": "string" },
            "dns_error_code": { "type": ["string", "null"] },
            "tls_alert": { "type": ["string", "null"] },
            "mtls_peer_cert_fingerprint_prefix": { "$ref": "#/$defs/nullableHashHex" },
            "observed_at": { "type": "string", "format": "date-time" },
            "source": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "device_id", "cert_fingerprint_prefix", "issuer_id", "subject_san_hash", "enrollment_status", "cert_not_before", "cert_not_after", "audit_event_id"],
          "properties": {
            "class": { "const": "CERT_IDENTITY" },
            "device_id": { "$ref": "#/$defs/uuid" },
            "cert_fingerprint_prefix": { "$ref": "#/$defs/nullableHashHex" },
            "issuer_id": { "type": ["string", "null"] },
            "subject_san_hash": { "$ref": "#/$defs/nullableHashHex" },
            "enrollment_status": { "type": "string" },
            "cert_not_before": { "type": ["string", "null"], "format": "date-time" },
            "cert_not_after": { "type": ["string", "null"], "format": "date-time" },
            "audit_event_id": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "device_id", "msi_product_code", "msi_exit_code", "agent_version", "installer_phase", "log_excerpt_redacted", "gpo_assignment_id"],
          "properties": {
            "class": { "const": "INSTALLER_MSI" },
            "device_id": { "$ref": "#/$defs/uuid" },
            "msi_product_code": { "type": ["string", "null"] },
            "msi_exit_code": { "type": "integer" },
            "agent_version": { "type": ["string", "null"] },
            "installer_phase": { "type": ["string", "null"] },
            "log_excerpt_redacted": { "$ref": "#/$defs/redactedString" },
            "gpo_assignment_id": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "device_id", "service_state", "agent_mode", "hmac_error_code", "last_heartbeat_at", "command_id", "agent_version"],
          "properties": {
            "class": { "const": "SERVICE_HMAC_MODE" },
            "device_id": { "$ref": "#/$defs/uuid" },
            "service_state": { "type": "string" },
            "agent_mode": { "type": "string" },
            "hmac_error_code": { "type": ["string", "null"] },
            "last_heartbeat_at": { "type": ["string", "null"], "format": "date-time" },
            "command_id": { "type": ["string", "null"] },
            "agent_version": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "device_id", "command_id", "result_submit_http_status", "backend_error_code", "request_id", "received_at", "idempotency_key_hash"],
          "properties": {
            "class": { "const": "BACKEND_RESULT_SUBMIT" },
            "device_id": { "$ref": "#/$defs/uuid" },
            "command_id": { "type": ["string", "null"] },
            "result_submit_http_status": { "type": "integer" },
            "backend_error_code": { "type": ["string", "null"] },
            "request_id": { "type": ["string", "null"] },
            "received_at": { "type": ["string", "null"], "format": "date-time" },
            "idempotency_key_hash": { "$ref": "#/$defs/nullableHashHex" }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["class", "device_id", "network_segment_id", "edr_vendor", "blocked_process_hash_prefix", "blocked_destination", "firewall_rule_id", "last_successful_contact_at"],
          "properties": {
            "class": { "const": "EDR_NETWORK" },
            "device_id": { "$ref": "#/$defs/uuid" },
            "network_segment_id": { "type": ["string", "null"] },
            "edr_vendor": { "type": "string" },
            "blocked_process_hash_prefix": { "$ref": "#/$defs/nullableHashHex" },
            "blocked_destination": { "type": ["string", "null"] },
            "firewall_rule_id": { "type": ["string", "null"] },
            "last_successful_contact_at": { "type": ["string", "null"], "format": "date-time" }
          }
        }
      ]
    },
    "classBinding": {
      "description": "Binds an item/event class discriminator to its evidence.class (Codex must-fix 1). $data is not available, so an if/then per class enforces equality.",
      "allOf": [
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "DNS_EDGE_MTLS" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "DNS_EDGE_MTLS" } } } } } },
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "CERT_IDENTITY" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "CERT_IDENTITY" } } } } } },
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "INSTALLER_MSI" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "INSTALLER_MSI" } } } } } },
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "SERVICE_HMAC_MODE" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "SERVICE_HMAC_MODE" } } } } } },
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "BACKEND_RESULT_SUBMIT" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "BACKEND_RESULT_SUBMIT" } } } } } },
        { "if": { "required": ["current_class"], "properties": { "current_class": { "const": "EDR_NETWORK" } } }, "then": { "properties": { "evidence_redacted": { "properties": { "class": { "const": "EDR_NETWORK" } } } } } }
      ]
    },
    "queueItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "org_id", "rollout_id", "wave_id", "device_id", "current_class", "current_state", "retry_count", "max_retries", "first_detected_at", "last_observed_at", "last_transition_at", "evidence_redacted", "owner_role", "classification_confidence", "version"],
      "$ref": "#/$defs/classBinding",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "org_id": { "$ref": "#/$defs/uuid" },
        "rollout_id": { "type": "string" },
        "wave_id": { "type": "string" },
        "device_id": { "$ref": "#/$defs/uuid" },
        "current_class": { "$ref": "#/$defs/failureClass" },
        "current_state": { "$ref": "#/$defs/queueState" },
        "retry_count": { "type": "integer", "minimum": 0 },
        "max_retries": { "type": "integer", "minimum": 0 },
        "first_detected_at": { "type": "string", "format": "date-time" },
        "last_observed_at": { "type": "string", "format": "date-time" },
        "last_transition_at": { "type": "string", "format": "date-time" },
        "evidence_redacted": { "$ref": "#/$defs/evidence" },
        "owner_role": { "type": "string" },
        "stop_line_contribution": { "type": ["boolean", "null"] },
        "escalation_issue_url": { "type": ["string", "null"], "format": "uri" },
        "waiver_reason": { "type": ["string", "null"] },
        "waived_by": { "type": ["string", "null"] },
        "waived_until": { "type": ["string", "null"], "format": "date-time" },
        "resolved_at": { "type": ["string", "null"], "format": "date-time" },
        "resolution_summary": { "$ref": "#/$defs/redactedString" },
        "classification_confidence": { "$ref": "#/$defs/confidence" },
        "classifier_version": { "type": ["string", "null"] },
        "version": { "type": "integer", "minimum": 0 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "description": "Append-only audit ledger row. The §4 transition matrix is ENFORCED here (Codex must-fix 2): allowed (from_state -> to_state) pairs, from_state required unless detected, resolved|waived -> new requires event_type=reopened + a source_signal.",
      "required": ["id", "failure_id", "event_type", "to_state", "class", "actor_type", "created_at"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "failure_id": { "$ref": "#/$defs/uuid" },
        "event_type": { "type": "string", "enum": ["detected", "transition", "retry", "reclassified", "escalated", "waived", "reopened", "resolved"] },
        "from_state": { "oneOf": [{ "$ref": "#/$defs/queueState" }, { "type": "null" }] },
        "to_state": { "$ref": "#/$defs/queueState" },
        "class": { "$ref": "#/$defs/failureClass" },
        "source_signal": { "type": ["string", "null"] },
        "redacted_evidence": { "oneOf": [{ "$ref": "#/$defs/evidence" }, { "type": "null" }] },
        "actor_type": { "type": "string", "enum": ["auto", "operator", "system"] },
        "actor_subject_hash": { "$ref": "#/$defs/nullableHashHex" },
        "classification_confidence": { "oneOf": [{ "$ref": "#/$defs/confidence" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        { "if": { "properties": { "event_type": { "not": { "const": "detected" } } } }, "then": { "required": ["from_state"], "properties": { "from_state": { "$ref": "#/$defs/queueState" } } } },
        { "if": { "required": ["event_type"], "properties": { "event_type": { "const": "detected" } } }, "then": { "properties": { "to_state": { "const": "new" }, "from_state": { "type": "null" } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "new" } } }, "then": { "properties": { "to_state": { "enum": ["retrying", "quarantined", "escalated", "resolved", "waived"] } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "retrying" } } }, "then": { "properties": { "to_state": { "enum": ["retrying", "quarantined", "escalated", "resolved", "waived"] } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "quarantined" } } }, "then": { "properties": { "to_state": { "enum": ["retrying", "escalated", "resolved", "waived"] } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "escalated" } } }, "then": { "properties": { "to_state": { "enum": ["retrying", "quarantined", "resolved", "waived"] } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "resolved" } } }, "then": { "required": ["source_signal"], "properties": { "to_state": { "const": "new" }, "event_type": { "const": "reopened" } } } },
        { "if": { "required": ["from_state"], "properties": { "from_state": { "const": "waived" } } }, "then": { "required": ["source_signal"], "properties": { "to_state": { "const": "new" }, "event_type": { "const": "reopened" } } } },
        { "if": { "properties": { "class": { "const": "DNS_EDGE_MTLS" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "DNS_EDGE_MTLS" } } }] } } } },
        { "if": { "properties": { "class": { "const": "CERT_IDENTITY" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "CERT_IDENTITY" } } }] } } } },
        { "if": { "properties": { "class": { "const": "INSTALLER_MSI" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "INSTALLER_MSI" } } }] } } } },
        { "if": { "properties": { "class": { "const": "SERVICE_HMAC_MODE" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "SERVICE_HMAC_MODE" } } }] } } } },
        { "if": { "properties": { "class": { "const": "BACKEND_RESULT_SUBMIT" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "BACKEND_RESULT_SUBMIT" } } }] } } } },
        { "if": { "properties": { "class": { "const": "EDR_NETWORK" } } }, "then": { "properties": { "redacted_evidence": { "anyOf": [{ "type": "null" }, { "properties": { "class": { "const": "EDR_NETWORK" } } }] } } } }
      ]
    },
    "waveFailureReport": {
      "$anchor": "waveFailureReport",
      "type": "object",
      "additionalProperties": false,
      "description": "Wave artifact export — the canonical runtime artifact. Validate an export with: validate against $defs/waveFailureReport (see validate.py). stop_line_status is backend-COMPUTED from the latest orchestrator metrics snapshot; export MUST fail closed rather than invent denominator fields when the snapshot is absent.",
      "required": ["schemaVersion", "rollout_id", "wave_id", "generated_at", "active_wave_size", "fleet_size", "wave_failed_count", "wave_failed_percent", "stale_24h_count", "stale_24h_percent", "stop_line_status", "per_class_counts", "enforcement"],
      "properties": {
        "schemaVersion": { "const": "failed-device-queue/v1" },
        "rollout_id": { "type": "string" },
        "wave_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "active_wave_size": { "type": "integer", "minimum": 0 },
        "fleet_size": { "type": "integer", "minimum": 0 },
        "wave_failed_count": { "type": "integer", "minimum": 0 },
        "wave_failed_percent": { "type": "number", "minimum": 0 },
        "stale_24h_count": { "type": "integer", "minimum": 0 },
        "stale_24h_percent": { "type": "number", "minimum": 0 },
        "stop_line_status": { "$ref": "#/$defs/stopLineStatus" },
        "per_class_counts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "DNS_EDGE_MTLS": { "type": "integer", "minimum": 0 },
            "CERT_IDENTITY": { "type": "integer", "minimum": 0 },
            "INSTALLER_MSI": { "type": "integer", "minimum": 0 },
            "SERVICE_HMAC_MODE": { "type": "integer", "minimum": 0 },
            "BACKEND_RESULT_SUBMIT": { "type": "integer", "minimum": 0 },
            "EDR_NETWORK": { "type": "integer", "minimum": 0 }
          }
        },
        "sample_items": { "type": "array", "items": { "$ref": "#/$defs/queueItem" } },
        "escalation_issue_refs": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "enforcement": {
          "type": "object",
          "additionalProperties": false,
          "description": "Honesty flags. The first three booleans state whether the runtime component is present and the export was produced through it. deployment_enforcement_active is a separate hard claim and MUST stay false until a rollout-gating control actually blocks expansion.",
          "required": ["live_ingest", "threshold_evaluator", "github_escalation_generator", "deployment_enforcement_active"],
          "properties": {
            "live_ingest": { "type": "boolean" },
            "threshold_evaluator": { "type": "boolean" },
            "github_escalation_generator": { "type": "boolean" },
            "deployment_enforcement_active": { "const": false }
          }
        }
      }
    }
  }
}
