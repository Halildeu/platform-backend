        "organizationId": "example-controller-tr",
        "displayName": "Example Türkiye Controller",
        "jurisdiction": "TR",
        "policyRef": "https://privacy.example.invalid/remote-support"
      },
      "processors": [],
      "storageRegions": ["tr-example-1"],
      "residencyMode": "single-region",
      "crossBorderTransfer": "deny",
      "destinationRegions": [],
      "transferSafeguardRef": null
    },
    "specialCategory": {
      "detectionFailureAction": "deny-session",
      "defaultAction": "pause-and-mask",
      "rules": [
        {
          "categoryId": "secrets",
