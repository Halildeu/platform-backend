    "notice": {
      "noticeVersion": "1.0.0",
      "defaultLocale": "tr-TR",
      "localizations": [
        {
          "locale": "tr-TR",
          "title": "Ekran görüntüleme isteği",
          "body": "Yetkili destek personeli, bildirilen destek amacıyla ekranınızı yalnızca görüntülemek istiyor. Bu oturum klavye, fare, pano, dosya aktarımı veya ağ tüneli yetkisi vermez; ekran içeriği kaydedilmez.",
          "allowLabel": "Bu oturum için izin ver",
          "denyLabel": "Reddet",
          "withdrawalText": "İzninizi oturum sırasında istediğiniz anda geri çekebilirsiniz.",
          "localAbortText": "Görünür oturum göstergesindeki Durdur denetimi bağlantıyı yerel olarak sonlandırır.",
          "contentDigest": "sha256:3ae213d7a5f805b7b5c1c2a1bd968b67ad6b78b45acfc364c0dda9c68e0ffb4d"
        }
      ]
    },
    "recording": {
      "mode": "disabled",
      "recordingIndicatorRequired": true
    },
    "retention": {
      "screenContent": {
        "persisted": false,
        "ttlSeconds": 0
      },
      "sessionMetadata": {
        "persisted": true,
        "ttlSeconds": 2592000
      },
      "auditRecords": {
        "persisted": true,
        "ttlSeconds": 2592000,
        "immutable": true
      },
      "legalHoldSupported": true
    },
    "dataGovernance": {
