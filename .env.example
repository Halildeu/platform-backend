COMPOSE_PROJECT_NAME=platform

POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=users

JWT_SECRET=change_me_super_secret_value
INTERNAL_API_KEY=change_me_internal_api_key
JWT_EXPIRATION=86400000

PERMISSION_DB_URL=jdbc:postgresql://postgres-db:5432/users
PERMISSION_DB_USERNAME=your_db_user
PERMISSION_DB_PASSWORD=your_db_password
EUREKA_SERVER_URL=http://discovery-server:8761/eureka
PERMISSION_SERVICE_PORT=8084
PERMISSION_SERVICE_BASE_URL=http://permission-service
AUTH_DB_SCHEMA=public
USER_DB_SCHEMA=public
PERMISSION_DB_SCHEMA=public
VARIANT_DB_SCHEMA=variant_service
CORE_DATA_DB_SCHEMA=core_data_service
PERMISSION_BOOTSTRAP_DEFAULT_ADMIN_ASSIGNMENTS_USER_TABLE=users

# OpenFGA / Zanzibar Authorization
ERP_OPENFGA_ENABLED=true
ERP_OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
SCOPE_CACHE_ENABLED=false
SCOPE_CACHE_TTL_SECONDS=30
SCOPE_CACHE_TTL_JITTER=3
SCOPE_CACHE_MAX_SIZE=5000
AUTHZ_VERSION_ENABLED=false

# Keycloak public hostname (REQUIRED for staging/prod — issuer mismatch breaks OIDC)
KC_HOSTNAME=https://your-domain.example.com
# Keycloak PostgreSQL password
KC_DB_PASSWORD=keycloak
